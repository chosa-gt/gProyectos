// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id_rol   Int       @id @default(autoincrement())
  nombre   String?   @db.VarChar(50)
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id_usuario Int      @id @default(autoincrement())
  nombre     String?  @db.VarChar(50)
  apellido   String?  @db.VarChar(50)
  correo     String   @unique @db.VarChar(100)
  contrasena String   @db.VarChar(255)
  id_rol     Int
  activo     Boolean  @default(true)
  tareas     Tarea[]
  refresh_tokens RefreshToken[]

  rol        Rol      @relation(fields: [id_rol], references: [id_rol])

  @@map("usuarios")
}

model Empresa {
  id_empresa Int       @id @default(autoincrement())
  nombre     String?   @db.VarChar(100)
  clientes   Cliente[]

  @@map("empresa")
}

model EstadoCliente {
  id_estado_cliente Int       @id @default(autoincrement())
  estado            String?   @db.VarChar(50)
  clientes          Cliente[]

  @@map("estado_cliente")
}

model Cliente {
  id_cliente        Int           @id @default(autoincrement())
  nombre            String?       @db.VarChar(100)
  correo            String?       @unique @db.VarChar(100)
  telefono          String?       @db.VarChar(50)
  id_empresa        Int
  id_estado_cliente Int
  proyectos         Proyecto[]

  empresa           Empresa       @relation(fields: [id_empresa], references: [id_empresa])
  estado_cliente    EstadoCliente @relation(fields: [id_estado_cliente], references: [id_estado_cliente])

  @@map("clientes")
}

model EstadoProyecto {
  id_estado_proyecto Int        @id @default(autoincrement())
  estado             String?    @db.VarChar(50)
  proyectos          Proyecto[]

  @@map("estado_proyecto")
}

model Proyecto {
  id_proyecto        Int            @id @default(autoincrement())
  nombre             String?        @db.VarChar(255)
  descripcion        String?
  fecha_inicio       DateTime       @db.Date
  fecha_fin          DateTime?      @db.Date
  id_cliente         Int
  id_estado_proyecto Int
  tareas             Tarea[]

  cliente            Cliente        @relation(fields: [id_cliente], references: [id_cliente])
  estado_proyecto    EstadoProyecto @relation(fields: [id_estado_proyecto], references: [id_estado_proyecto])

  @@map("proyectos")
}

model Prioridad {
  id_prioridad     Int     @id @default(autoincrement())
  nombre_prioridad String? @db.VarChar(50)
  tareas           Tarea[]

  @@map("prioridad")
}

model EstadoTarea {
  id_estado_tarea Int     @id @default(autoincrement())
  estado          String? @db.VarChar(50)
  tareas          Tarea[]

  @@map("estado_tarea")
}

model Tarea {
  id_tarea        Int       @id @default(autoincrement())
  tarea           String?   @db.VarChar(255)
  descripcion     String?
  fecha_inicio    DateTime  @db.Date
  fecha_fin       DateTime? @db.Date
  id_proyecto     Int
  id_usuario      Int
  id_prioridad    Int
  id_estado_tarea Int

  proyecto        Proyecto    @relation(fields: [id_proyecto], references: [id_proyecto])
  usuario         Usuario     @relation(fields: [id_usuario], references: [id_usuario])
  prioridad       Prioridad   @relation(fields: [id_prioridad], references: [id_prioridad])
  estado_tarea    EstadoTarea @relation(fields: [id_estado_tarea], references: [id_estado_tarea])

  @@map("tareas")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  id_usuario Int
  expires_at DateTime
  created_at DateTime @default(now())

  usuario    Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@map("refresh_tokens")
}